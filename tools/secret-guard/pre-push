#!/usr/bin/env bash
# Keel secret-guard — pre-push hook. The hard outward boundary: scan the commits being pushed.
# Reads stdin lines: <local ref> <local sha> <remote ref> <remote sha>
set -euo pipefail
here="$(cd "$(dirname "$0")" && pwd)"
scan="$here/secret-scan.sh"
[ -x "$scan" ] || scan="$(command -v secret-scan.sh || true)"
if [ -z "${scan:-}" ] || [ ! -x "$scan" ]; then
  echo "secret-guard: scanner not found next to hook" >&2
  exit 1
fi

z="0000000000000000000000000000000000000000"
status=0
while read -r _localref localsha _remoteref remotesha; do
  [ "$localsha" = "$z" ] && continue                        # branch deletion — nothing to scan
  if [ "$remotesha" = "$z" ]; then
    # new branch: scan every commit not already on a remote
    base="$(git rev-list "$localsha" --not --remotes 2>/dev/null | tail -1)"
    if [ -n "$base" ] && git rev-parse -q --verify "${base}^" >/dev/null 2>&1; then
      range="${base}^..${localsha}"
    else
      # base is the repo's ROOT commit (its first push — the common case), so `${base}^` doesn't
      # exist and the old range silently scanned nothing. Diff from the empty tree instead, so the
      # whole initial history is scanned rather than waved through.
      range="$(git hash-object -t tree /dev/null)..${localsha}"
    fi
  else
    range="${remotesha}..${localsha}"
  fi
  "$scan" --range "$range" || status=1
done
exit "$status"
